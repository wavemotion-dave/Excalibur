/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

EXCALIBURMNU MENU DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Settings...\tCtrl+S",        IDM_SETTINGS
        MENUITEM "System &Usage Stats...    \tCtrl+U", IDM_USAGESTATS
        MENUITEM "&Define Custom Set...\tCtrl+D", IDM_DEFINECUSTOM
        MENUITEM "&Program Manager...\tCtrl+P", IDM_MACRO
        MENUITEM "E&xit\tCtrl+X",               IDM_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Copy X \tCtrl+C",            IDM_COPYXTOCLIPBOARD
        MENUITEM "Copy &All Stack\tCtrl+A",     IDM_COPYALLTOCLIPBOARD
        MENUITEM "&Paste X\tCtrl+V",            IDM_COPYCLIPBOARDTOX
    END
    POPUP "&Bank"
    BEGIN
        MENUITEM "&Scientific",                 IDM_SCIENTIFIC
        MENUITEM "&Statistics",                 IDM_STATS
        MENUITEM "&Financial",                  IDM_FINANCIAL
        MENUITEM "&Conversion",                 IDM_CONVERSION
        MENUITEM "&Geometry",                   IDM_GEOMETRY
        MENUITEM "&Comp Sci",                   IDM_COMPSCI
        MENUITEM "&Physics",                    IDM_PHYSICS
        MENUITEM "&Complex/Vector",             IDM_COMPLEX
        MENUITEM "&Program I",                  IDM_MACROBANK
        MENUITEM "&Program II",                 IDM_MISC
        MENUITEM "&Custom",                     IDM_CUSTOM
        MENUITEM SEPARATOR
        MENUITEM "&Always On Top",              IDM_ALWAYSONTOP
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Excalibur Help",             IDM_EXCALIBURHELP
        MENUITEM "&About Excalibur",            IDM_ABOUTPROGRAM
    END
END


